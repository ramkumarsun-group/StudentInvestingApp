# ─── Test Environment ────────────────────────────────────────────────────────
# Copy to .env.test and fill in values before running E2E or integration tests.
# Uses a SEPARATE test database to avoid polluting dev data.

NODE_ENV=test

# ─── Database (test DB — separate from dev) ──────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/studentinvesting_test
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=test-jwt-secret-32-chars-padded--
JWT_REFRESH_SECRET=test-refresh-secret-32-chars-pad-
NEXTAUTH_SECRET=test-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
INTERNAL_API_SECRET=test-internal-secret-min-16

# ─── Market Data (use sandbox keys for testing) ───────────────────────────────
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://data.alpaca.markets
COINGECKO_API_KEY=
NEWS_API_KEY=

# ─── Playwright ───────────────────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_API_URL=http://localhost:4000/api/v1
