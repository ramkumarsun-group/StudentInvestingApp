# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/studentinvesting
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-32-chars-min
JWT_REFRESH_SECRET=change-me-refresh-32-chars-min
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
# Internal secret used by Next.js server to authenticate server-to-server calls to the API
INTERNAL_API_SECRET=change-me-internal-secret-min-16-chars

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Market Data ─────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://data.alpaca.markets

COINGECKO_API_KEY=

NEWS_API_KEY=

# ─── AI (Phase 3) ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Stripe (Phase 3) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STUDENT_PRO_PRICE_ID=
STRIPE_SCHOOL_LICENSE_PRICE_ID=

# ─── Email ────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@studentinvesting.app

# ─── App ──────────────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
NODE_ENV=development
